# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Connection string do NeonDB (Postgres serverless)
# Obter em: https://console.neon.tech → seu projeto → Connection string
DATABASE_URL=

# ─── Segurança ────────────────────────────────────────────────────────────────
# Chave AES-256 para criptografar credenciais do gateway no banco
# Gerar com: openssl rand -base64 32
ENCRYPTION_KEY=
