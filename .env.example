# ─── Aplicação ────────────────────────────────────────────────────────────────
# URL pública da aplicação — usado em links de e-mail (sem barra final)
APP_URL=https://mistoec.com.br

# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Connection string do NeonDB (Postgres serverless)
# Obter em: https://console.neon.tech → seu projeto → Connection string
DATABASE_URL=

# ─── Segurança ────────────────────────────────────────────────────────────────
# Chave AES-256 para criptografar credenciais do gateway no banco (32 bytes = 64 hex chars)
# Gerar com: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Gateway de Pagamento ─────────────────────────────────────────────────────
# Token para validação de assinatura HMAC nos webhooks do ASAAS
# Definido no painel ASAAS → Configurações → Notificações → Token
ASAAS_WEBHOOK_TOKEN=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# CDN de imagens — obter em: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── E-mail ────────────────────────────────────────────────────────
# Credenciais SMTP para envio de e-mails transacionais (confirmação de pedido, etc.)
MAILTRAP_HOST=
MAILTRAP_PORT=
MAILTRAP_USER=
MAILTRAP_PASS=
MAILTRAP_FROM=
